-- ══════════════════════════════
local function onItem(name, count, src)
    if not CONFIG.NOTIFY_ITEMS then return end
    if not sessionItems[name] then sessionItems[name]={count=0, firstSeen=os.time()} end
    sessionItems[name].count = sessionItems[name].count + count
    local tier = TIER_LOOKUP[name]
    addLog(("📦 %s ×%d | %s | %s"):format(name, count, tier or "—", src))
    print(("[SP] 📦 %s ×%d | %s | %s"):format(name, count, tier or "—", src))
    -- recent drops list (max 8)
    table.insert(recentDrops, 1, {name=name, tier=tier, count=count, time=os.time()})
    if #recentDrops > 8 then table.remove(recentDrops) end
    if tier and CONFIG.PING_ON_RARE then
        table.insert(alertBuffer, {name=name, count=count, tier=tier})
        if alertTimer then task.cancel(alertTimer) end
        alertTimer = task.delay(3, flushAlert)
    end
end

