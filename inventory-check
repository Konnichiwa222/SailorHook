local function fmtTime(s)
    return ("%02dh%02dm%02ds"):format(math.floor(s/3600), math.floor(s%3600/60), s%60)
end
local function pingStr()
    local id = tostring(CONFIG.DISCORD_ID or ""):match("^%s*(.-)%s*$")
    return (#id > 5) and ("<@"..id..">") or ""
end
local function totalItems()
    local n = 0
    for _, v in pairs(sessionItems) do n = n + v.count end
    return n
end
local function parseNum(s)
    if s == nil then return nil end
    s = tostring(s):gsub(",",""):gsub("%$",""):gsub("%s","")
    local n = tonumber(s); if n then return n end
    local b, sf = s:match("^(%-?%d+%.?%d*)([KkMmBb])$")
    b = tonumber(b); if not b then return nil end
    if sf:lower()=="k" then return math.floor(b*1e3+.5) end
    if sf:lower()=="m" then return math.floor(b*1e6+.5) end
    if sf:lower()=="b" then return math.floor(b*1e9+.5) end
end
local function fmtNum(n)
    n = n or 0
    if n>=1e9 then return ("%.1fB"):format(n/1e9):gsub("%.0B","B") end
    if n>=1e6 then return ("%.1fM"):format(n/1e6):gsub("%.0M","M") end
    if n>=1e3 then return ("%.1fK"):format(n/1e3):gsub("%.0K","K") end
    return tostring(n)
end
local function addLog(txt)
    local ts = os.date("%H:%M:%S")
    table.insert(logLines, 1, "["..ts.."] "..txt)
    if #logLines > 40 then table.remove(logLines) end
end

