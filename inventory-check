-- ══════════════════════════════
local cache = {}
local function isCached(k)
    if cache[k] then return true end
    cache[k]=true; task.delay(4, function() cache[k]=nil end)
    return false
end
local pending = {}

local function handlePair(first, second, ref)
    first=tostring(first or ""); second=tostring(second or "")
    local cs, inlineName = first:match("[Oo]btained%s+[xX]?(%d+)%s+(.+)")
    local nm
    if cs and inlineName then nm=inlineName:match("^%s*(.-)%s*$")
    else
        cs=first:match("[Oo]btained%s+[xX]?(%d+)")
        nm=second:match("^%s*(.-)%s*$")
    end
    if nm then nm=nm:gsub("^[xX]%d+%s+",""):match("^%s*(.-)%s*$") end
    if cs and nm and nm~="" and not nm:find("^%[") and not nm:find("%$") then
        local k="ui_"..nm.."_"..math.floor(os.time()/4)
        if not isCached(k) then onItem(nm, tonumber(cs) or 1, "UI") end
    end
    pending[ref]=nil
end

local function watchHolder(h)
    h.ChildAdded:Connect(function(c)
        if not (c:IsA("TextLabel") or c:IsA("TextBox")) then return end
        task.wait()
        local t=tostring(c.Text or "")
        if t=="" then return end
        if t:match("^[Oo]btained") or t:match("^[Ee]arned") then
            pending[h]={text=t}
            task.delay(2, function() if pending[h] and pending[h].text==t then pending[h]=nil end end)
        elseif pending[h] then handlePair(pending[h].text, t, h) end
    end)
end

local function hookInventoryRemotes()
    local remotesRoot = ReplicatedStorage:FindFirstChild("Remotes")
    if not remotesRoot then warn("[SP] Remotes không tồn tại"); return end
    local notify   = remotesRoot:FindFirstChild("NotifyItemDrop")
    local updateInv= remotesRoot:FindFirstChild("UpdateInventory")
    if notify and notify:IsA("RemoteEvent") then
        notify.OnClientEvent:Connect(function(data)
            local name=data and data.name; local qty=tonumber(data and data.quantity) or 1
            if type(name)=="string" and name~="" then
                local k="r_notify_"..name.."_"..math.floor(os.time()/2)
                if not isCached(k) then onItem(name, qty, "NotifyItemDrop") end
            end
        end)
        addLog("✅ Hooked NotifyItemDrop")
    end
    if updateInv and updateInv:IsA("RemoteEvent") then
        updateInv.OnClientEvent:Connect(function(tbl)
            if type(tbl)~="table" then return end
            local nb=math.floor(os.time()/2)
            for _, it in pairs(tbl) do
                local name=type(it)=="table" and it.name or nil
                local qty =type(it)=="table" and tonumber(it.quantity) or nil
                if type(name)=="string" and qty and qty>0 then
                    local key="inv_"..name; local prev=pending[key]
                    if not prev then pending[key]=qty
                    elseif qty>prev then
                        local delta=qty-prev; pending[key]=qty
                        local k="r_update_"..name.."_"..nb
                        if not isCached(k) then onItem(name, delta, "UpdateInventory") end
                    else pending[key]=qty end
                end
            end
        end)
        addLog("✅ Hooked UpdateInventory")
    end
end

local function startDetection()
    hookInventoryRemotes()
    local pg=LP:WaitForChild("PlayerGui",10)
    if not pg then return end
    local hooked={}
    local function tryHook(o)
        if o.Name=="AutoSizeHolder" and not hooked[o] then hooked[o]=true; watchHolder(o) end
    end
    for _, d in ipairs(pg:GetDescendants()) do tryHook(d) end
    pg.DescendantAdded:Connect(function(d) task.wait(); tryHook(d) end)
    pg.DescendantRemoving:Connect(function(d) if hooked[d] then hooked[d]=nil; pending[d]=nil end end)
    addLog("✅ Detection ON")
    print("[SP] ✅ Detection ON")
end

