local MAX_REPORT_BODY_CHARS = 3500

local function fitBodySize(body)
    body = tostring(body or "")
    if #body <= MAX_REPORT_BODY_CHARS then
        return body, false
    end
    local remain = #body - MAX_REPORT_BODY_CHARS
    local clipped = body:sub(1, MAX_REPORT_BODY_CHARS) .. ("\n\n… +%d ký tự nữa (quá dài cho Discord webhook)"):format(remain)
    return clipped, true
end

local function makeCard(title, body, color, ping)
    local safeBody, clipped = fitBodySize(body)
    if clipped then
        warn("[SP] Report body quá dài, đã tự rút gọn để tránh lỗi 400")
    end

    if CONFIG.USE_COMPONENTS_V2 then return makeV2Card(title, safeBody, color, ping) end
    return makeEmbedCard(title, safeBody, color, ping)
end

local function buildAlert(buf, color)
    local grp = {Secret={}, Mythic={}, Legendary={}}
    for _, e in ipairs(buf) do
        if grp[e.tier] then table.insert(grp[e.tier], ("• %s ×%d"):format(e.name, e.count)) end
    end
    local lines = {}
    if #grp.Secret   > 0 then table.insert(lines, "🔴 **SECRET**\n"   ..table.concat(grp.Secret,"\n")) end
    if #grp.Mythic   > 0 then table.insert(lines, "🟠 **MYTHIC**\n"   ..table.concat(grp.Mythic,"\n")) end
    if #grp.Legendary> 0 then table.insert(lines, "🟡 **LEGENDARY**\n"..table.concat(grp.Legendary,"\n")) end
    local body = table.concat(lines,"\n\n")..("\n\n👤 `%s`  ·  📦 `×%d`  ·  ⏱️ `%s`"):format(
        LP.Name, totalItems(), fmtTime(os.time()-sessionStart))
    return makeCard("🔔 Drop Alert!", body, color, pingStr())
end

local function buildReport()    
    local ord = {Secret=1, Mythic=2, Legendary=3}
    local sorted = {}
    local rare = {Secret=0, Mythic=0, Legendary=0}

    for name, d in pairs(sessionItems) do
        local count = tonumber(d and d.count) or 0
        table.insert(sorted, {name=tostring(name), count=count})
        local tier = TIER_LOOKUP[name]
        if tier and rare[tier] then
            rare[tier] = rare[tier] + count
        end
    end

    table.sort(sorted, function(a, b)
        local ta = ord[TIER_LOOKUP[a.name]] or 4
        local tb = ord[TIER_LOOKUP[b.name]] or 4
        if ta ~= tb then return ta < tb end
        if a.count ~= b.count then return a.count > b.count end
        return a.name < b.name
    end)

    local featured = {}
    local others = {}
    local featuredLookup = {
        ["clan reroll"] = true,
        ["trait reroll"] = true,
        ["race reroll"] = true,
    }

    for _, d in ipairs(sorted) do
        local line = "• " .. d.name .. " ×" .. d.count
        if featuredLookup[string.lower(d.name)] then
            table.insert(featured, line)
        else
            table.insert(others, line)
        end
    end

    local featuredText = #featured > 0 and table.concat(featured, "\n") or "*Chưa có Clan/Trait/Race Reroll*"
    local otherText = #others > 0 and table.concat(others, "\n") or "*Không có item khác*"

    local delta = sessionGems - gemsAtLastReport
    gemsAtLastReport = sessionGems

    local acColor = 0x2B5FD9
    if rare.Secret > 0 then acColor = 0xFF0000
    elseif rare.Mythic > 0 then acColor = 0xFF4500
    elseif rare.Legendary > 0 then acColor = 0xFFAA00 end

    local body = (
        "💎 **%s** ( +%s )   ·   📦 **×%d**   ·   ⏱️ **%s**\n" ..
        "🔴 Secret **×%d**  ·  🟠 Mythic **×%d**  ·  🟡 Legendary **×%d**\n\n" ..
        "✨ **Drop nổi bật**\n%s\n\n" ..
        "📦 **Item khác**\n%s"
    ):format(
        fmtNum(sessionGems), fmtNum(delta), totalItems(), fmtTime(os.time()-sessionStart),
        rare.Secret, rare.Mythic, rare.Legendary,
        featuredText, otherText
    )

    return makeCard("📋 Session Report", body, acColor, pingStr())
end

