        bl.TextXAlignment = Enum.TextXAlignment.Left
        bl.TextColor3 = GREEN
    end

    mkSectionLabel("WEBHOOK URL", 1)
    local wbBox = mkInputBox("https://discord.com/api/webhooks/...", CONFIG.WEBHOOK_URL, 2)

    mkSectionLabel("DISCORD ID  /  INTERVAL (s)", 3)
    local inlineBoxes = mkInlineInputs({
        {"Discord ID (để ping)", CONFIG.DISCORD_ID, 0.65},
        {tostring(CONFIG.REPORT_INTERVAL), tostring(CONFIG.REPORT_INTERVAL), 0.35},
    }, 4)
    local idBox  = inlineBoxes[1]
    local intBox = inlineBoxes[2]

    local function applyFormToConfig()
        local rawInterval = tonumber(intBox.Text)
        CONFIG.WEBHOOK_URL = wbBox.Text:match("^%s*(.-)%s*$") or ""
        CONFIG.DISCORD_ID = idBox.Text:match("^%s*(.-)%s*$") or ""
        CONFIG.REPORT_INTERVAL = sanitizeInterval(rawInterval)
        intBox.Text = tostring(CONFIG.REPORT_INTERVAL)
        return rawInterval
    end

    mkSectionLabel("TOGGLES", 5)
    mkToggle("● Webhook ON",  "○ Webhook OFF",    CONFIG.WEBHOOK_ENABLED,   6,  function(v) CONFIG.WEBHOOK_ENABLED=v; saveConfigAuto() end)
    mkToggle("● Items ON",    "○ Items OFF",       CONFIG.NOTIFY_ITEMS,      7,  function(v) CONFIG.NOTIFY_ITEMS=v; saveConfigAuto() end)
    mkToggle("● Gems ON",     "○ Gems OFF",        CONFIG.NOTIFY_GEMS,       8,  function(v) CONFIG.NOTIFY_GEMS=v; saveConfigAuto() end)
    mkToggle("● Ping Rare ON","○ Ping Rare OFF",   CONFIG.PING_ON_RARE,      9,  function(v) CONFIG.PING_ON_RARE=v; saveConfigAuto() end)
    mkToggle("● Disconnect ON","○ Disconnect OFF", CONFIG.NOTIFY_DISCONNECT, 10, function(v) CONFIG.NOTIFY_DISCONNECT=v; saveConfigAuto() end)
    mkToggle("● Components v2 ON","○ Embeds",      CONFIG.USE_COMPONENTS_V2, 11, function(v) CONFIG.USE_COMPONENTS_V2=v; saveConfigAuto() end)

    mkSectionLabel("ACTIONS", 12)

    -- Save button (full width)
    mkBtn("💾  SAVE CONFIG", ACCENT, 13, function()
        local oldInterval = tonumber(CONFIG.REPORT_INTERVAL) or 60
        local rawInterval = applyFormToConfig()
        local url = CONFIG.WEBHOOK_URL

        if not isUrlValid(url) then
            statusLbl.Text = "✗ URL không hợp lệ"
            statusLbl.TextColor3 = RED
            statusDot.BackgroundColor3 = RED
            return
        end

        local fileSaved = saveConfig()
        local guardMsg = ""
        if rawInterval == nil or math.floor(rawInterval) ~= CONFIG.REPORT_INTERVAL or oldInterval ~= CONFIG.REPORT_INTERVAL then
            guardMsg = (" (guard %d-%ds)"):format(MIN_REPORT_INTERVAL, MAX_REPORT_INTERVAL)
        end

        if fileSaved then
            statusLbl.Text = ("✓ Saved to file — interval %ds%s"):format(CONFIG.REPORT_INTERVAL, guardMsg)
            addLog("💾 Config saved → "..SAVE_FILE)
        else
            statusLbl.Text = ("✓ Saved (no writefile) — interval %ds%s"):format(CONFIG.REPORT_INTERVAL, guardMsg)
            addLog("💾 Config saved (session only — executor không hỗ trợ writefile)")
        end
        statusLbl.TextColor3 = GREEN
        statusDot.BackgroundColor3 = GREEN
    end)

    -- Report / Test row
    mkBtnRow({
        {"📤 REPORT", GOLD, function()
            if not isUrlValid(CONFIG.WEBHOOK_URL) then
                statusLbl.Text="✗ URL chưa hợp lệ"; statusLbl.TextColor3=RED; return
            end
            queueWebhook(buildReport())
            statusLbl.Text="📤 Report queued"; statusLbl.TextColor3=GOLD
            addLog("📤 Manual report queued")
        end},
        {"🧪 TEST", PURPLE, function()
            local rawInterval = applyFormToConfig()
            if not isUrlValid(CONFIG.WEBHOOK_URL) then
                statusLbl.Text="✗ URL chưa hợp lệ"; statusLbl.TextColor3=RED; return
            end
            saveConfigAuto()
            task.spawn(function()
                local payload=buildTest()
                local ok,body=pcall(HttpService.JSONEncode,HttpService,payload)
                if not ok then statusLbl.Text="✗ JSON lỗi"; statusLbl.TextColor3=RED; return end
                local okHttp,code,_,attempts=sendWithRetry(CONFIG.WEBHOOK_URL,body,3)
                if okHttp then
                    local guardTag = (rawInterval and math.floor(rawInterval)==CONFIG.REPORT_INTERVAL) and "" or " | guard interval"
                    statusLbl.Text=("✓ Test thành công (%d try)%s"):format(attempts or 1, guardTag)
                    statusLbl.TextColor3=GREEN
                    addLog("✅ Webhook test OK")
                else
                    statusLbl.Text=("✗ Test lỗi %s (%d try)"):format(tostring(code), attempts or 1)
                    statusLbl.TextColor3=RED
                    addLog("❌ Webhook test FAILED code="..tostring(code))
                end
            end)
        end},
    }, 14)

    -- Reset (full width)
    mkBtn("🗑️  RESET SESSION", RED, 15, function()
        sessionItems={}; sessionGems=0; gemsAtLastReport=0
        sessionStart=os.time(); lastGemsValue=-1; recentDrops={}
        statusLbl.Text="🗑️ Session reset"; statusLbl.TextColor3=RED
        addLog("🗑️ Session reset")
    end)

    -- ────────────────────────────────────────────────
    --  TAB 2: STATS
    -- ────────────────────────────────────────────────
    local statsPage = pages[2]

    local function mkStatCard(parent, x, y, w, h)
        local f = Instance.new("Frame", parent)
        f.Size = UDim2.new(0, w, 0, h)
        f.Position = UDim2.new(0, x, 0, y)
        f.BackgroundColor3 = BG2
        f.BorderSizePixel = 0
        Instance.new("UICorner",f).CornerRadius = UDim.new(0,8)
        local s = Instance.new("UIStroke",f)
        s.Color = BORDER; s.Thickness = 1
        return f
    end

    local pad2 = 10
    local cardW = math.floor((W - pad2*2 - 6) / 2)
    local cardH = 60

    local sc1 = mkStatCard(statsPage, pad2, pad2, cardW, cardH)
    local sc2 = mkStatCard(statsPage, pad2+cardW+6, pad2, cardW, cardH)
    local sc3 = mkStatCard(statsPage, pad2, pad2+cardH+6, cardW, cardH)
    local sc4 = mkStatCard(statsPage, pad2+cardW+6, pad2+cardH+6, cardW, cardH)

    local function mkStatContent(card, icon, labelTxt, valTxt, subTxt, valColor)
        local lbl = Instance.new("TextLabel",card)
        lbl.Size = UDim2.new(1,-8,0,12)
        lbl.Position = UDim2.new(0,8,0,7)
        lbl.BackgroundTransparency = 1
        lbl.Font = Enum.Font.GothamBold
        lbl.Text = icon.." "..labelTxt
        lbl.TextSize = 12
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextColor3 = MUTED

        local val = Instance.new("TextLabel",card)
        val.Name = "Val"
        val.Size = UDim2.new(1,-8,0,22)
        val.Position = UDim2.new(0,8,0,21)
        val.BackgroundTransparency = 1
        val.Font = Enum.Font.GothamBold
        val.Text = valTxt
        val.TextSize = 18
        val.TextXAlignment = Enum.TextXAlignment.Left
        val.TextColor3 = valColor or TEXT

        local sub = Instance.new("TextLabel",card)
        sub.Name = "Sub"
        sub.Size = UDim2.new(1,-8,0,12)
        sub.Position = UDim2.new(0,8,0,43)
        sub.BackgroundTransparency = 1
        sub.Font = Enum.Font.Gotham
        sub.Text = subTxt
        sub.TextSize = 11
        sub.TextXAlignment = Enum.TextXAlignment.Left
        sub.TextColor3 = GREEN

        return val, sub
    end

    local gemsVal, gemsSub = mkStatContent(sc1, "💎", "GEMS GAINED", "0", "this session", ACCENT)
    local itemsVal, itemsSub = mkStatContent(sc2, "📦", "ITEMS FOUND", "0", "since reset", TEXT)
    local queueVal, _ = mkStatContent(sc3, "📡", "QUEUE", "0", "pending sends", ACCENT)
    local timerVal, _ = mkStatContent(sc4, "⏱", "NEXT REPORT", "60s", "interval", GOLD)

    -- Recent drops list
    local dropsY = pad2 + (cardH+6)*2 + 6
    local dropsLabel = Instance.new("TextLabel", statsPage)
    dropsLabel.Size = UDim2.new(1,-pad2*2,0,14)
    dropsLabel.Position = UDim2.new(0,pad2,0,dropsY)
    dropsLabel.BackgroundTransparency = 1
    dropsLabel.Font = Enum.Font.GothamBold
    dropsLabel.Text = "RECENT DROPS"
    dropsLabel.TextSize = 12
    dropsLabel.TextXAlignment = Enum.TextXAlignment.Left
    dropsLabel.TextColor3 = MUTED

    local dropsScroll = Instance.new("ScrollingFrame", statsPage)
    dropsScroll.Size = UDim2.new(1,-pad2*2,1,-(dropsY+20))
    dropsScroll.Position = UDim2.new(0,pad2,0,dropsY+18)
    dropsScroll.BackgroundTransparency = 1
    dropsScroll.BorderSizePixel = 0
    dropsScroll.ScrollBarThickness = 2
    dropsScroll.ScrollBarImageColor3 = ACCENT
    dropsScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    dropsScroll.CanvasSize = UDim2.new(0,0,0,0)

    local dropsList = Instance.new("UIListLayout",dropsScroll)
    dropsList.SortOrder = Enum.SortOrder.LayoutOrder
    dropsList.Padding = UDim.new(0,3)

    local tierColors = {
        Secret    = Color3.fromRGB(255, 0, 0),
        Mythic    = ORANGE,
        Legendary = GOLD,
    }

    local dropRows = {}
    for i = 1, 8 do
        local row = Instance.new("Frame",dropsScroll)
        row.Size = UDim2.new(1,0,0,26)
        row.BackgroundColor3 = BG2
        row.BorderSizePixel = 0
        row.LayoutOrder = i
        row.Visible = false
        Instance.new("UICorner",row).CornerRadius = UDim.new(0,6)
        Instance.new("UIStroke",row).Color = BORDER

        local accent3 = Instance.new("Frame",row)
        accent3.Name = "TierAccent"
        accent3.Size = UDim2.new(0,2,1,-8)
        accent3.Position = UDim2.new(0,4,0,4)
        accent3.BackgroundColor3 = MUTED
        accent3.BorderSizePixel = 0
        Instance.new("UICorner",accent3).CornerRadius = UDim.new(1,0)

        local tierTag = Instance.new("TextLabel",row)
        tierTag.Name = "Tier"
        tierTag.Size = UDim2.new(0,52,1,0)
        tierTag.Position = UDim2.new(0,10,0,0)
        tierTag.BackgroundTransparency = 1
        tierTag.Font = Enum.Font.GothamBold
        tierTag.Text = "COMMON"
        tierTag.TextSize = 12
        tierTag.TextXAlignment = Enum.TextXAlignment.Left
        tierTag.TextColor3 = MUTED

        local nameLbl = Instance.new("TextLabel",row)
        nameLbl.Name = "Name"
        nameLbl.Size = UDim2.new(1,-100,1,0)
        nameLbl.Position = UDim2.new(0,66,0,0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Font = Enum.Font.Gotham
        nameLbl.Text = "—"
        nameLbl.TextSize = 11
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextColor3 = TEXT

        local cntLbl = Instance.new("TextLabel",row)
        cntLbl.Name = "Count"
        cntLbl.Size = UDim2.new(0,30,1,0)
        cntLbl.Position = UDim2.new(1,-34,0,0)
        cntLbl.BackgroundTransparency = 1
        cntLbl.Font = Enum.Font.GothamBold
        cntLbl.Text = "×1"
        cntLbl.TextSize = 11
        cntLbl.TextXAlignment = Enum.TextXAlignment.Right
        cntLbl.TextColor3 = MUTED

        table.insert(dropRows, {row=row, accent=accent3, tier=tierTag, name=nameLbl, count=cntLbl})
    end

    local function refreshDrops()
        for i, dr in ipairs(dropRows) do
            local d = recentDrops[i]
            if d then
                dr.row.Visible = true
                local tc = tierColors[d.tier] or MUTED
                dr.accent.BackgroundColor3 = tc
                dr.tier.Text = d.tier and d.tier:upper():sub(1,6) or "COMMON"
                dr.tier.TextColor3 = tc
                dr.name.Text = d.name
                dr.count.Text = "×"..d.count
            else
                dr.row.Visible = false
            end
        end
    end

    -- ────────────────────────────────────────────────
    --  TAB 3: LOG
    -- ────────────────────────────────────────────────
    local logScroll = Instance.new("ScrollingFrame", pages[3])
    logScroll.Size = UDim2.new(1,-8,1,-8)
    logScroll.Position = UDim2.new(0,4,0,4)
    logScroll.BackgroundTransparency = 1
    logScroll.BorderSizePixel = 0
    logScroll.ScrollBarThickness = 2
    logScroll.ScrollBarImageColor3 = ACCENT
    logScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    logScroll.CanvasSize = UDim2.new(0,0,0,0)

    local logLayout = Instance.new("UIListLayout",logScroll)
    logLayout.SortOrder = Enum.SortOrder.LayoutOrder
    logLayout.Padding = UDim.new(0,1)

    local logLabels = {}
    for i = 1, 30 do
        local l = Instance.new("TextLabel",logScroll)
        l.Size = UDim2.new(1,0,0,14)
        l.BackgroundTransparency = 1
        l.Font = Enum.Font.Gotham
        l.Text = ""
        l.TextSize = 12
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.TextColor3 = MUTED
        l.LayoutOrder = i
        l.Visible = false
        table.insert(logLabels, l)
    end

    local function refreshLog()
        for i, lbl in ipairs(logLabels) do
            local line = logLines[i]
            if line then
                lbl.Visible = true
                lbl.Text = line
                -- color based on content
                if line:find("✅") then lbl.TextColor3 = GREEN
                elseif line:find("❌") or line:find("✗") then lbl.TextColor3 = RED
                elseif line:find("📦") then
                    local tier = line:match("| (%a+) |")
                    if tier=="Mythic" then lbl.TextColor3=ORANGE
                    elseif tier=="Legendary" then lbl.TextColor3=GOLD
                    elseif tier=="Secret" then lbl.TextColor3=RED
                    else lbl.TextColor3=TEXT end
                elseif line:find("💾") or line:find("📤") then lbl.TextColor3=ACCENT
                else lbl.TextColor3 = MUTED end
            else
                lbl.Visible = false
            end
        end
    end

    -- ── Tab switching ─────────────────────────────────
    local function switchTab(idx)
        activeTab = idx
        for i, tb in ipairs(tabBtns) do
            local isActive = (i==idx)
            TweenService:Create(tb, TweenInfo.new(0.12), {
                TextColor3 = isActive and ACCENT or MUTED
            }):Play()
            tb.Underline.Visible = isActive
        end
        for i, p in ipairs(pages) do
            p.Visible = (i==idx)
        end
        if idx==2 then refreshDrops() end
        if idx==3 then refreshLog() end
    end

    for i, tb in ipairs(tabBtns) do
        tb.MouseButton1Click:Connect(function() switchTab(i) end)
    end

    -- ── Minimize ─────────────────────────────────────
    local minimized = false
    local function applyMinimizedState()
        TweenService:Create(win, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, W, 0, minimized and 34 or H)
        }):Play()
        header.Visible = not minimized
        statBar.Visible = not minimized
        for i, p in ipairs(pages) do
            p.Visible = (not minimized) and (i == activeTab)
        end
        collapseBtn.Text = minimized and "+" or "—"
    end

    local function toggleMinimized()
        minimized = not minimized
        applyMinimizedState()
    end

    collapseBtn.MouseButton1Click:Connect(toggleMinimized)
    minBtn.MouseButton1Click:Connect(toggleMinimized)

    -- ── Drag ─────────────────────────────────────────
    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil

    local function startDrag(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1 and i.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        dragging = true
        dragInput = i
        dragStart = i.Position
        startPos = win.Position

        i.Changed:Connect(function()
            if i.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end

    local function updateDrag(i)
        if not dragging then return end
        if i ~= dragInput and i.UserInputType ~= Enum.UserInputType.MouseMovement and i.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        local d = i.Position - dragStart
        win.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end

    tabBar.InputBegan:Connect(startDrag)
    header.InputBegan:Connect(startDrag)

    tabBar.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
            dragInput = i
        end
    end)
    header.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
            dragInput = i
        end
    end)

    UIS.InputChanged:Connect(updateDrag)

    -- ── Slide in ─────────────────────────────────────
    TweenService:Create(win,
        TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Position = UDim2.new(0, 12, 0.5, -H/2)}
    ):Play()

    -- ── Real-time updater ────────────────────────────
    local lastStatUpdate = 0
    RunService.Heartbeat:Connect(function()
        local now = os.time()
        if now - lastStatUpdate < 1 then return end
        lastStatUpdate = now

        local nextR = CONFIG.REPORT_INTERVAL - ((now - lastReportTime) % CONFIG.REPORT_INTERVAL)
        local delta = sessionGems - gemsAtLastReport

        -- status bar
        statusLbl.Text = ("report %ds  |  q:%d"):format(nextR, #webhookQueue)
        statusRight.Text = ("💎+%s  📦%d"):format(fmtNum(sessionGems), totalItems())

        -- stats tab cards
        gemsVal.Text = fmtNum(sessionGems)
        gemsSub.Text = "(+"..fmtNum(delta).." since last report)"
        itemsVal.Text = tostring(totalItems())
        queueVal.Text = tostring(#webhookQueue)
        queueVal.TextColor3 = #webhookQueue>0 and GOLD or ACCENT
        timerVal.Text = nextR.."s"
        timerVal.TextColor3 = nextR<10 and RED or (nextR<20 and GOLD or ACCENT)

        -- refresh active tab content
        if activeTab==2 then refreshDrops() end
        if activeTab==3 then refreshLog() end
    end)

    return statusLbl
end

