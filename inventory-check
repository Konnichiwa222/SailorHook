local function hookStats()
    local function wGem(v)
        local nm=v.Name:lower()
        if not (nm=="gems" or nm=="gem") then return end
        if not CONFIG.NOTIFY_GEMS then return end
        local path=v:GetFullName()
        if not gemSourcePath then
            gemSourcePath=path
            local iv0=parseNum(v.Value)
            if type(iv0)=="number" then lastGemsValue=iv0 end
            addLog("💎 Gem source: "..gemSourcePath)
        end
        v:GetPropertyChangedSignal("Value"):Connect(function()
            if gemSourcePath and path~=gemSourcePath then return end
            local nv=parseNum(v.Value)
            if type(nv)~="number" then return end
            if lastGemsValue==-1 then lastGemsValue=nv
            elseif nv>lastGemsValue then sessionGems=sessionGems+(nv-lastGemsValue); lastGemsValue=nv
            else lastGemsValue=nv end
        end)
        local iv=parseNum(v.Value)
        if type(iv)=="number" and lastGemsValue==-1 then lastGemsValue=iv end
    end
    local function wObj(obj)
        if not obj then return end
        for _, v in ipairs(obj:GetChildren()) do
            if v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("StringValue") then wGem(v) end
        end
        obj.ChildAdded:Connect(function(v)
            task.wait()
            if v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("StringValue") then wGem(v) end
        end)
    end
    LP.ChildAdded:Connect(function(c)
        if c.Name=="leaderstats" or c.Name=="PlayerData" or c.Name=="Stats" then
            task.wait(0.1); wObj(c)
        end
    end)
    for _, n in ipairs({"leaderstats","PlayerData","Stats","Data"}) do
        local o=LP:FindFirstChild(n); if o then wObj(o) end
    end
end

local function pollGems()
    if not CONFIG.NOTIFY_GEMS then return end
    if not gemSourcePath or gemSourcePath=="" then return end
    local parts={}
    for p in gemSourcePath:gmatch("[^%.]+") do table.insert(parts,p) end
    local cur=game
    for _, name in ipairs(parts) do cur=cur:FindFirstChild(name); if not cur then break end end
    if not cur or not cur:IsA("ValueBase") then return end
    local n=parseNum(cur.Value)
    if type(n)~="number" then return end
    if lastGemsValue==-1 then lastGemsValue=n
    elseif n>lastGemsValue then sessionGems=sessionGems+(n-lastGemsValue); lastGemsValue=n
    elseif n~=lastGemsValue then lastGemsValue=n end
end

