local SAVE_FILE = "sailorhook_config.json"
local MIN_REPORT_INTERVAL = 15
local MAX_REPORT_INTERVAL = 3600

-- Các key được lưu/load (không lưu BOT_NAME, BOT_AVATAR, DEBUG)
local SAVE_KEYS = {
    "WEBHOOK_URL","DISCORD_ID","REPORT_INTERVAL",
    "WEBHOOK_ENABLED","NOTIFY_ITEMS","NOTIFY_GEMS",
    "NOTIFY_DISCONNECT","PING_ON_RARE","USE_COMPONENTS_V2",
}

local function clamp(n, minN, maxN)
    if n < minN then return minN end
    if n > maxN then return maxN end
    return n
end

local function sanitizeInterval(v)
    local n = tonumber(v) or CONFIG.REPORT_INTERVAL or 60
    n = math.floor(n)
    return clamp(n, MIN_REPORT_INTERVAL, MAX_REPORT_INTERVAL)
end

local function sanitizeConfig()
    CONFIG.WEBHOOK_URL = tostring(CONFIG.WEBHOOK_URL or ""):match("^%s*(.-)%s*$") or ""
    CONFIG.DISCORD_ID = tostring(CONFIG.DISCORD_ID or ""):match("^%s*(.-)%s*$") or ""
    CONFIG.REPORT_INTERVAL = sanitizeInterval(CONFIG.REPORT_INTERVAL)

    CONFIG.WEBHOOK_ENABLED   = not not CONFIG.WEBHOOK_ENABLED
    CONFIG.NOTIFY_ITEMS      = not not CONFIG.NOTIFY_ITEMS
    CONFIG.NOTIFY_GEMS       = not not CONFIG.NOTIFY_GEMS
    CONFIG.NOTIFY_DISCONNECT = not not CONFIG.NOTIFY_DISCONNECT
    CONFIG.PING_ON_RARE      = not not CONFIG.PING_ON_RARE
    CONFIG.USE_COMPONENTS_V2 = not not CONFIG.USE_COMPONENTS_V2
end

local function fileExists(path)
    if isfile then return isfile(path) end
    if syn and syn.is_file then return syn.is_file(path) end
    return false
end

local function readFile(path)
    if readfile then return readfile(path) end
    if syn and syn.read_file then return syn.read_file(path) end
    return nil
end

local function writeFile(path, content)
    if writefile then writefile(path, content); return true end
    if syn and syn.write_file then syn.write_file(path, content); return true end
    return false
end

local function loadConfig()
    local ok, exists = pcall(fileExists, SAVE_FILE)
    if not ok or not exists then sanitizeConfig(); return false end
    local ok2, raw = pcall(readFile, SAVE_FILE)
    if not ok2 or not raw or raw == "" then sanitizeConfig(); return false end
    local ok3, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(raw)
    end)
    if not ok3 or type(data) ~= "table" then
        warn("[SP] ⚠ Config file bị lỗi, dùng mặc định")
        sanitizeConfig()
        return false
    end
    for _, key in ipairs(SAVE_KEYS) do
        if data[key] ~= nil then CONFIG[key] = data[key] end
    end
    sanitizeConfig()
    print("[SP] ✅ Đã load config từ "..SAVE_FILE)
    return true
end

local function saveConfig()
    sanitizeConfig()
    local data = {}
    for _, key in ipairs(SAVE_KEYS) do data[key] = CONFIG[key] end
    local ok, raw = pcall(function()
        return game:GetService("HttpService"):JSONEncode(data)
    end)
    if not ok then warn("[SP] ⚠ Không encode được config: "..tostring(raw)); return false end
    local ok2, err = pcall(writeFile, SAVE_FILE, raw)
    if not ok2 then
        warn("[SP] ⚠ Không ghi được file ("..tostring(err)..") — executor có thể không hỗ trợ writefile")
        return false
    end
    print("[SP] 💾 Config đã lưu → "..SAVE_FILE)
    return true
end

local autoSaveBusy = false
local autoSavePending = false
local function saveConfigAuto()
    if autoSaveBusy then
        autoSavePending = true
        return
    end
    autoSaveBusy = true
    task.spawn(function()
        saveConfig()
        autoSaveBusy = false
        if autoSavePending then
            autoSavePending = false
            saveConfigAuto()
        end
    end)
end

