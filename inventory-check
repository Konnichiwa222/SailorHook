-- ══════════════════════════════
local function dbg(...)
    if CONFIG.WEBHOOK_DEBUG then print("[SP][DBG]", ...) end
end

local function summarizePayload(payload)
    if type(payload) ~= "table" then return "payload=non-table" end
    local hasEmbeds = type(payload.embeds)=="table" and #payload.embeds > 0
    local hasComps  = type(payload.components)=="table" and #payload.components > 0
    return ("mode=%s embeds=%s comps=%s"):format(
        CONFIG.USE_COMPONENTS_V2 and "v2" or "embed",
        tostring(hasEmbeds), tostring(hasComps))
end

local function parseHttpResult(res)
    if type(res) ~= "table" then return nil, nil, nil end
    local code = tonumber(res.StatusCode or res.Status or res.status_code or 0) or 0
    local body = res.Body or res.body or res.ResponseBody
    return (code >= 200 and code < 300), code, body
end

local function sendHTTP(url, body)
    local sendUrl = url
    if CONFIG.USE_COMPONENTS_V2 and not tostring(sendUrl):find("with_components=true",1,true) then
        sendUrl = sendUrl .. (tostring(sendUrl):find("?",1,true) and "&" or "?") .. "with_components=true"
    end
    local data = {
        Url = sendUrl, Method = "POST",
        Headers = { ["Content-Type"] = "application/json", ["Accept"] = "application/json" },
        Body = body,
    }
    local fns = {
        {name="syn.request",    fn=function() return (syn and syn.request) and syn.request(data) end},
        {name="http_request",   fn=function() return http_request and http_request(data) end},
        {name="request",        fn=function() return request and request(data) end},
        {name="http.request",   fn=function() return (http and http.request) and http.request(data) end},
        {name="fluxus.request", fn=function() return (fluxus and fluxus.request) and fluxus.request(data) end},
        {name="Krnl.request",   fn=function() return (Krnl and Krnl.request) and Krnl.request(data) end},
    }
    for _, entry in ipairs(fns) do
        local okCall, res = pcall(entry.fn)
        if okCall and res then
            local okHttp, code = parseHttpResult(res)
            dbg(("api=%s ok=%s code=%s"):format(entry.name, tostring(okHttp), tostring(code)))
            return res
        end
    end
    local ok2, err2 = pcall(function()
        return HttpService:PostAsync(sendUrl, body, Enum.HttpContentType.ApplicationJson, false)
    end)
    if not ok2 then warn("[SP] HTTP thất bại: "..tostring(err2)) end
    return ok2 and {StatusCode=200} or nil
end

-- ══════════════════════════════
--   QUEUE
-- ══════════════════════════════
local function isUrlValid(url)
    url = tostring(url or ""):match("^%s*(.-)%s*$")
    return url ~= "" and (
        url:find("^https://discord%.com/api/webhooks/") or
        url:find("^https://ptb%.discord%.com/api/webhooks/") or
        url:find("^https://canary%.discord%.com/api/webhooks/") or
        url:find("^https://discordapp%.com/api/webhooks/")
    ) ~= nil
end

local function queueWebhook(payload)
    if not CONFIG.WEBHOOK_ENABLED then return end
    if not isUrlValid(CONFIG.WEBHOOK_URL) then warn("[SP] ⚠ URL chưa hợp lệ!"); return end
    dbg("queue+1", summarizePayload(payload))
    table.insert(webhookQueue, payload)
end

local function sendWithRetry(url, payloadBody, maxRetries)
    maxRetries = tonumber(maxRetries) or 3
    local backoffs = {2, 5, 10}

    local attempt = 1
    while attempt <= (maxRetries + 1) do
        local res = sendHTTP(url, payloadBody)
        local okHttp, code, respBody = parseHttpResult(res)
        if okHttp then
            return true, code, respBody, attempt
        end

        local shouldRetry = false
        if okHttp == nil then
            shouldRetry = true
        elseif tonumber(code) == 429 or (tonumber(code) and tonumber(code) >= 500) then
            shouldRetry = true
        end

        if attempt > maxRetries or not shouldRetry then
            return false, code, respBody, attempt
        end

        local waitSec = backoffs[attempt] or backoffs[#backoffs]
        dbg(("retry attempt=%d wait=%ss code=%s"):format(attempt + 1, tostring(waitSec), tostring(code)))
        task.wait(waitSec)
        attempt = attempt + 1
    end

    return false, nil, nil, maxRetries + 1
end

local function flushQueue()
    if #webhookQueue == 0 then return end
    local now = os.time()
    if now - lastSentTime < SEND_COOLDOWN then return end
    lastSentTime = now
    local payload = table.remove(webhookQueue, 1)
    task.spawn(function()
        local ok, body = pcall(HttpService.JSONEncode, HttpService, payload)
        if not ok then warn("[SP] JSON encode lỗi: "..tostring(body)); return end
        local okHttp, code = sendWithRetry(CONFIG.WEBHOOK_URL, body, 3)
        dbg(("flush ok=%s code=%s"):format(tostring(okHttp), tostring(code)))
        if not okHttp then
            warn("[SP] Webhook flush failed code="..tostring(code))
        end
    end)
end

