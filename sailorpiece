local function Corner(p, px)
    local c = Instance.new("UICorner") ; c.CornerRadius = UDim.new(0, px or 4) ; c.Parent = p ; return c
end
local function Stroke(p, col, th)
    local s = Instance.new("UIStroke") ; s.Color = col or C.border ; s.Thickness = th or 1 ; s.Parent = p ; return s
end
local function Tw(obj, t, props, sty, dir)
    return TweenService:Create(obj, TweenInfo.new(t, sty or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
end

local function Ripple(btn, x, y)
    local r = Instance.new("Frame")
    r.BackgroundColor3 = C.white ; r.BackgroundTransparency = 0.8 ; r.BorderSizePixel = 0
    r.ZIndex = 20 ; r.AnchorPoint = Vector2.new(0.5,0.5) ; r.Size = UDim2.new(0,0,0,0)
    r.Position = UDim2.new((x - btn.AbsolutePosition.X)/btn.AbsoluteSize.X, 0, (y - btn.AbsolutePosition.Y)/btn.AbsoluteSize.Y, 0)
    r.Parent = btn ; Corner(r, 999)
    Tw(r, 0.4, {Size=UDim2.new(2.8,0,2.8,0), BackgroundTransparency=1}):Play()
    Debris:AddItem(r, 0.42)
end

