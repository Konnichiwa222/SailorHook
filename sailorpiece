    playIcon.Text = "▶" ; playIcon.Size = UDim2.new(0,20,1,0) ; playIcon.Position = UDim2.new(1,-24,0,0)
    playIcon.BackgroundTransparency = 1 ; playIcon.Font = Enum.Font.Gotham ; playIcon.TextSize = 14 ; playIcon.TextColor3 = C.textDim ; playIcon.Parent = btn

    btn.MouseEnter:Connect(function() Tw(btnStroke, 0.15, {Color = C.borderH}):Play() ; Tw(playIcon, 0.15, {TextColor3 = C.white}):Play() end)
    btn.MouseLeave:Connect(function() Tw(btnStroke, 0.15, {Color = C.border}):Play() ; Tw(playIcon, 0.15, {TextColor3 = C.textDim}):Play() end)
    btn.MouseButton1Down:Connect(function(x,y) Ripple(btn,x,y) end)
    
